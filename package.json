    "watch": "ng build --watch --configuration development",
    "check": "pnpm run check:format && pnpm run check:style && pnpm run check:lint && echo ✅",
    "check:style": "stylelint \"**/*.{css,scss}\"",
    "check:format": "prettier --check --cache .",
    "check:lint": "ng lint",
    "fix": "pnpm fix:format && pnpm fix:style && pnpm fix:lint && echo ✨",
    "fix:style": "stylelint \"**/*.{css,scss}\" --fix",
    "fix:format": "prettier --write --cache .",
    "fix:lint": "ng lint --fix",
    "test": "ng test --watch=false",
    "build:android:prod:apk": "tauri android build --apk --target aarch64",
    "build:android:prod": "tauri android build",
    "tauri": "tauri"
  },
  "private": true,
